# Chemin racine du projet (optionnel, détecté automatiquement)
PROJECT_ROOT=

# Base SQLite
DATABASE_URL=sqlite:////Users/hugochavier/psych-ia-ressources/storage/psych_ia.db

# ChromaDB
CHROMA_PERSIST_DIR=storage/chroma

# Embeddings (modèle sentence-transformers, multilingue)
